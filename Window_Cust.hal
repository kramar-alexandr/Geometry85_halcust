external inner function boolean IsEnterprise();
external inner function boolean HasLanguages();
external inner function boolean HasMultiCurrency();
external inner function boolean HasBase2();
external inner function boolean HasModNL();
external inner function boolean StandardHansa();

SetLangMode(LangUkrainian,"UKR",2);

window AccRulesLClass:1
wtag("language","UKR"), wtag("product","*"), wtag("productcode","*"), wtag("device","computer")
begin
real i,h,h1,h2,h3,h4,h5,h6,hs,v,vs,vm,hl,l,t,f,fs,tabv,v2;
  string 255 label;
  integer tilenr;
WindowBegin("Налаштуванні рахунків курсових різниць",AccRulesLClass,CGmlist,-);
  SpawnClass(AccRulesDClass);
  SetWRect(74,80,560,298);
  Sizeable(-1,-1,0,0);
  UseView(AccRulesVc);
  RecordList(4,17,-21,-39);
  RlColKey(4,4,"Код",Code,false,Code);
  RlColKey(81,81,"Коментар",Comment,false,Comment);
  RlCol(-80,-80,"Виключено",Closed,false);

  SearchField("Пошук");
  EndWindow;
end;

